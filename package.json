{
  "name": "ps-script-manager",
  "version": "2.0.9",
  "description": "PS Script Manager - PowerShell Script Verwaltung",
  "main": "main.js",
  "author": "Tobias Scherer",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "canvas": "^3.2.3",
    "electron-updater": "^6.8.3",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.2"
  },
  "overrides": {
    "glob": "^13.0.6",
    "rimraf": "^5.0.0"
  },
  "build": {
    "appId": "de.liquidflow.scriptmanager",
    "productName": "PS Script Manager",
    "copyright": "© 2025 Tobias Scherer",
    "icon": "assets/icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "main/**/*.js",
      "database/db.js",
      "renderer/index.html",
      "renderer/js/**/*.js",
      "assets/**",
      "node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "PS.Script.Manager.Setup.${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PS Script Manager",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "LiquidFlow-design",
      "repo": "ScriptManager"
    },
    "extraResources": [
      {
        "from": "lib/",
        "to": "lib/",
        "filter": ["**/*.ps1"]
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
